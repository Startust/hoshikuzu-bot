// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model PageCache {
  url       String   @id @db.VarChar(768)
  source    String   @db.VarChar(64)
  title     String?  @db.VarChar(512)
  text      String   @db.LongText
  fetchedAt DateTime @default(now()) @map("fetched_at") @db.DateTime(3)
  ttlMs     Int      @map("ttl_ms") // 如果 ttl 可能 > 24 天（ms 超 2^31），用 BigInt

  @@index([source], name: "idx_page_cache_source")
  @@map("page_cache")
}

model SearchCache {
  source      String   @db.VarChar(64)
  query       String   @db.VarChar(512)
  resultsJson String   @map("results_json") @db.LongText
  fetchedAt   DateTime @default(now()) @map("fetched_at") @db.DateTime(3)
  ttlMs       Int      @map("ttl_ms")

  @@id([source, query])
  @@index([source], name: "idx_search_cache_source")
  @@map("search_cache")
}

model RankingConfig {
  discordGuildId  String  @id @map("discord_guild_id") @db.VarChar(32)
  notifyChannelId String? @map("notify_channel_id") @db.VarChar(32)
  flyffServerId   Int     @default(23) @map("flyff_server_id")

  @@map("ranking_config")
}

model WatchedFlyffGuild {
  discordGuildId String @map("discord_guild_id") @db.VarChar(32)
  flyffGuildName String @map("flyff_guild_name") @db.VarChar(64)

  @@id([discordGuildId, flyffGuildName])
  @@map("watched_flyff_guilds")
}

model RankingSnapshot {
  flyffServerId Int    @map("flyff_server_id")
  username      String @db.VarChar(64)

  rank           Int     @map("rank")
  level          Int
  job            String  @db.VarChar(32) // 你 job 若更长就调
  flyffGuildName String? @map("flyff_guild_name") @db.VarChar(64)
  playtime       String? @db.VarChar(32)
  serverText     String? @map("server_text") @db.VarChar(64)

  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@id([flyffServerId, username])
  @@index([flyffServerId, rank], name: "idx_server_rank")
  @@map("ranking_snapshot")
}

model RankingEvent {
  id            BigInt @id @default(autoincrement())
  flyffServerId Int    @map("flyff_server_id")
  eventType     String @map("event_type") @db.VarChar(16) // "guild" | "rename"

  // 对 guild 变动：username 有意义；对 rename：beforeName/afterName 有意义
  username    String? @db.VarChar(64)
  beforeValue String? @map("before_value") @db.VarChar(128)
  afterValue  String? @map("after_value") @db.VarChar(128)

  // rename 专用
  beforeName String? @map("before_name") @db.VarChar(64)
  afterName  String? @map("after_name") @db.VarChar(64)
  score      Int?
  reasonJson String? @map("reason_json") @db.LongText

  // 可选：把当时的快照信息也记录一下，历史展示更有内容
  rank           Int?
  level          Int?
  job            String? @db.VarChar(32)
  flyffGuildName String? @map("flyff_guild_name") @db.VarChar(64)

  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(3)

  @@index([flyffServerId, createdAt], name: "idx_event_server_time")
  @@index([flyffServerId, username, createdAt], name: "idx_event_user_time")
  @@map("ranking_event")
}

model DiscoveredFlyffGuild {
  flyffServerId  Int      @map("flyff_server_id")
  flyffGuildName String   @map("flyff_guild_name") @db.VarChar(64)
  lastSeenAt     DateTime @default(now()) @updatedAt @map("last_seen_at") @db.DateTime(3)

  @@id([flyffServerId, flyffGuildName])
  @@index([flyffServerId, lastSeenAt], name: "idx_discovered_guild_server_seen")
  @@index([flyffServerId, flyffGuildName], name: "idx_discovered_guild_server_name")
  @@map("discovered_flyff_guilds")
}

model GuildAllowlist {
  discordGuildId String   @id @map("discord_guild_id") @db.VarChar(32)
  note           String?  @db.VarChar(255)
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("guild_allowlist")
}
