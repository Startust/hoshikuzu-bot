LOCAL_TTS_MODEL_DIR=data/models/VoxCPM2
LOCAL_TTS_AUDIO_DIR=data/audio
LOCAL_TTS_REFERENCE_WAV=data/reference/neutral-reference.wav
LOCAL_TTS_AUTO_REFERENCE=1
LOCAL_TTS_REFERENCE_TEXT=这是一个用于固定发音音色的参考声音。请用清晰、自然、稳定的语速朗读。
LOCAL_TTS_PUBLIC_BASE_URL=
LOCAL_TTS_MAX_TEXT_CHARS=160
LOCAL_TTS_OPTIMIZE=0
LOCAL_TTS_BATCH_LIMIT=20
LOCAL_TTS_RETRY_FAILED_AFTER_HOURS=72
LOCAL_TTS_CFG_VALUE=1.7
LOCAL_TTS_INFERENCE_TIMESTEPS=16
LOCAL_TTS_TARGET_DBFS=-20
LOCAL_TTS_PEAK_LIMIT=0.95
LOCAL_TTS_JAPANESE_READING=1
LOCAL_TTS_JAPANESE_DICT=core
LOCAL_TTS_AWS_CLI_PATH=C:\Program Files\Amazon\AWSCLIV2\aws.exe
LOCAL_TTS_AWS_PROFILE=default
